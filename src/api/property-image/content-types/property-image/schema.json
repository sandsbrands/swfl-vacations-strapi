{
  "kind": "collectionType",
  "collectionName": "property_images",
  "info": {
    "singularName": "property-image",
    "pluralName": "property-images",
    "displayName": "Property_Image"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "caption": {
      "type": "text"
    },
    "alt_text": {
      "type": "string"
    },
    "ownerrez_photo_id": {
      "type": "string"
    },
    "content_hash": {
      "type": "string"
    },
    "sort_order": {
      "type": "integer"
    },
    "property": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::property.property",
      "inversedBy": "images"
    }
  }
}
