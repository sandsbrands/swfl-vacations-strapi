{
  "kind": "collectionType",
  "collectionName": "travel_guides",
  "info": {
    "singularName": "travel-guide",
    "pluralName": "travel-guides",
    "displayName": "Travel Guide"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "excerpt": {
      "type": "text"
    },
    "content": {
      "type": "blocks"
    },
    "featured_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "author": {
      "type": "string"
    },
    "published_date": {
      "type": "date"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Area Guides",
        "Things to Do",
        "Property Spotlights",
        "Restaurants & Food",
        "Travel Tips",
        "Local Events & Seasonal"
      ]
    },
    "seo_title": {
      "type": "string"
    },
    "seo_description": {
      "type": "text"
    },
    "related_property": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::property.property"
    }
  }
}
